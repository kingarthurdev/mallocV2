{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build C Program",
			"type": "shell",
			"command": "gcc",
			"args": [
				"-g",
				"-o",
				"${workspaceFolder}/a.out",
				"${workspaceFolder}/main.c",
				"${workspaceFolder}/libtdmm/tdmm.c",
				"-lm"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": ["$gcc"]
		}
	]
}
